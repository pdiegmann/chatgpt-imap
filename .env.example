IMAP_ACCOUNT_ID=default
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_TLS=true
IMAP_USERNAME=user@example.com
IMAP_PASSWORD=your-app-password
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_TLS=true
LOG_LEVEL=INFO

# Transport: "stdio" (default, for local/subprocess use) or "http" (for ChatGPT over HTTPS)
MCP_TRANSPORT=stdio

# Required when MCP_TRANSPORT=http.
# Public HTTPS base URL used for OAuth discovery and MCP requests, e.g. https://mcp.example.com
MCP_BASE_URL=

# Single-user password shown on the OAuth sign-in page
MCP_OAUTH_PASSWORD=

# TCP port to listen on when MCP_TRANSPORT=http (default: 3000)
MCP_PORT=3000

# Optional HTTP bind host (default: 0.0.0.0)
MCP_HOST=0.0.0.0

# Optional token lifetimes in seconds
MCP_OAUTH_ACCESS_TOKEN_TTL=3600
MCP_OAUTH_REFRESH_TOKEN_TTL=2592000
