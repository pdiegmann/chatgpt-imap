IMAP_ACCOUNT_ID=default
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_TLS=true
IMAP_USERNAME=user@example.com
IMAP_PASSWORD=your-app-password
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_TLS=true
LOG_LEVEL=INFO

# Transport: "stdio" (default, for local/subprocess use) or "http" (for ChatGPT Developer Mode over HTTPS)
MCP_TRANSPORT=stdio

# Required when MCP_TRANSPORT=http. Set to a long random secret, e.g.: openssl rand -hex 32
MCP_AUTH_TOKEN=

# TCP port to listen on when MCP_TRANSPORT=http (default: 3000)
MCP_PORT=3000
